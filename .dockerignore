# Rust build artifacts (huge, rebuilt inside Docker)
target/

# Node modules (reinstalled inside Docker)
**/node_modules

# Git
.git/
.github/

# Dev-only assets and databases
dev_assets/
dev_assets_seed/

# Build outputs that get regenerated
packages/local-web/dist/
packages/remote-web/dist/
remote-frontend/dist/

# Docker files (prevent recursive inclusion)
Dockerfile*
.dockerignore
docker-compose*.yml

# IDE / editor
.vscode/
.cursor/
.idea/
*.swp
*.swo
*~

# OS generated
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.*

# Logs and temp
logs/
*.log
tmp/
temp/
coverage/

# Documentation (not needed in build)
docs/
*.md
!README.md
!AGENTS.md
!CLAUDE.md

# CI/CD (not needed in build)
buildspec.yml

# NPX package artifacts
*.tgz
*.tar.gz
npx-cli/dist/
